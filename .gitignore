# Build outputs
Build/
build/
*_build/
DerivedData/
out/

# Xcode
*.xcodeproj/xcuserdata/
*.xcworkspace/
xcuserdata/
*.xcuserstate

# Visual Studio / Windows build artifacts
*.vcxproj.user
.vs/
x64/
x86/
*.sln.docstates

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
_deps/

# Compiled objects / binaries
*.o
*.obj
*.d
*.a
*.lib
*.exe
*.dll
*.dylib
*.so

# Plugin build outputs (only the actual built plugin files — keep golden reference
# expected/ WAVs and any checked-in factory presets, those are tracked on purpose)
*.component
*.vst3
!Docs/GoldenReference/expected/**/*.wav

# Test runner binaries
Tests/*.out
/PluginNameTests

# OS clutter
.DS_Store
Thumbs.db

# Editor/IDE
.vscode/
.idea/
*.swp

# Python (TestHarness scripts, if you add any here)
__pycache__/
*.pyc
.venv/

# Scratch/render output — golden reference baselines under Docs/GoldenReference/expected/
# are checked in deliberately; only ignore ad hoc renders outside that folder
/tmp_renders/
